generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  peserta
}

enum TipeSoal {
  pilihan_ganda
  esai
}

enum Babak {
  penyisihan
  semi_final
  final
}

enum StatusSoal {
  belum
  aktif
  selesai
}

model Tim {
  id      Int     @id @default(autoincrement())
  nama    String
  fotoTim String?
  role    Role    @default(peserta)

  username String @unique
  password String

  grup       Int   @default(1)
  tahapAktif Babak @default(penyisihan)

  skorBabak SkorBabak[]
  riwayat   RiwayatJawaban[]
}

model SkorBabak {
  id    Int   @id @default(autoincrement())
  timId Int
  babak Babak
  poin  Int   @default(0)

  tim Tim @relation(fields: [timId], references: [id], onDelete: Cascade)

  @@unique([timId, babak])
}

model PaketSoal {
  id         Int    @id @default(autoincrement())
  nama       String
  babak      Babak
  daftarSoal Soal[]
}

model Soal {
  id           Int      @id @default(autoincrement())
  pertanyaan   String   @db.Text
  tipe         TipeSoal
  opsiJawaban  Json?
  jawabanBenar String   @db.Text
  poin         Int      @default(10)

  status StatusSoal @default(belum)

  paketSoalId Int
  paketSoal   PaketSoal @relation(fields: [paketSoalId], references: [id], onDelete: Cascade)

  riwayat RiwayatJawaban[]
}

model RiwayatJawaban {
  id     Int @id @default(autoincrement())
  timId  Int
  soalId Int

  jawabanTim  String  @db.Text
  isBenar     Boolean
  poinDidapat Int

  waktuMenjawab DateTime @default(now())

  tim  Tim  @relation(fields: [timId], references: [id], onDelete: Cascade)
  soal Soal @relation(fields: [soalId], references: [id], onDelete: Cascade)
}
