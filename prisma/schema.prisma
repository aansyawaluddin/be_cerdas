generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  peserta
}

enum KategoriSoal {
  b_indo
  b_inggris
  mtk
  ipa
}

enum TipeSoal {
  pilihan_ganda
  esai
  memori
}

enum Babak {
  penyisihan
  semi_final
  final
}

enum StatusSoal {
  belum     
  aktif     
  selesai  
}

model Tim {
  id          Int       @id @default(autoincrement())
  nama        String
  fotoTim     String?   
  role        Role      @default(peserta)
  
  username    String    @unique
  password    String    

  grup        Int       @default(1) 
  tahapAktif  Babak     @default(penyisihan)
  isEliminated Boolean  @default(false)
  
  skorBabak   SkorBabak[]
  riwayat     RiwayatJawaban[]
  taruhan     TaruhanSoal[]
}

model SkorBabak {
  id        Int      @id @default(autoincrement())
  timId     Int
  babak     Babak
  poin      Int      @default(0)

  tim       Tim      @relation(fields: [timId], references: [id], onDelete: Cascade)

  @@unique([timId, babak])
}

model PaketSoal {
  id          Int       @id @default(autoincrement())
  nama        String   
  babak       Babak    
  daftarSoal  Soal[]   
}

model Soal {
  id            Int        @id @default(autoincrement())
  pertanyaan    String     @db.Text
  
  kategori      KategoriSoal
  tipe          TipeSoal   
  
  opsiJawaban   Json?      
  jawabanBenar  String     @db.Text
  poin          Int        @default(25) 
  
  status        StatusSoal @default(belum)
  waktuMulai    DateTime?  
  
  paketSoalId   Int
  paketSoal     PaketSoal  @relation(fields: [paketSoalId], references: [id], onDelete: Cascade)

  riwayat       RiwayatJawaban[]
  taruhan       TaruhanSoal[]
}

model TaruhanSoal {
  id        Int      @id @default(autoincrement())
  timId     Int
  soalId    Int
  poin      Int      

  tim       Tim      @relation(fields: [timId], references: [id], onDelete: Cascade)
  soal      Soal     @relation(fields: [soalId], references: [id], onDelete: Cascade)

  @@unique([timId, soalId])
}

model RiwayatJawaban {
  id            Int      @id @default(autoincrement())
  timId         Int
  soalId        Int
  
  jawabanTim    String   @db.Text 
  isBenar       Boolean            
  poinDidapat   Int      
  
  waktuMenjawab DateTime @default(now()) 

  tim           Tim      @relation(fields: [timId], references: [id], onDelete: Cascade)
  soal          Soal     @relation(fields: [soalId], references: [id], onDelete: Cascade)
}